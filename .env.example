# StudyBand Environment Variables Configuration
# Copy this file to '.env' and fill in your keys.

# Groq API Key (from https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Band Room ID (from the URL of your Band.ai chat room)
BAND_ROOM_ID=your_band_room_id_here

# Optional: Groq LLM model name (defaults to llama-3.3-70b-versatile)
# Alternatives: llama-3.1-8b-instant, mixtral-8x7b-32768, llama3-8b-8192
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: AI/ML API Key (from https://aimlapi.com)
AIMLAPI_API_KEY=your_aimlapi_key_here

